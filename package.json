{
  "name": "tongxuebox_nuxt4",
  "private": true,
  "author": {
    "name": "keleen",
    "email": "619492093@qq.com"
  },
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "ci:eslint": "eslint -f json src -o ./.ci/eslint.json",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint . && stylelint --allow-empty-input \"**/*.{css,less,scss}\"",
    "lint:fix": "prettier --write . && eslint --fix . && stylelint --allow-empty-input --fix \"**/*.{css,less,scss}\"",
    "prepare": "husky",
    "preview": "nuxt preview"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,mjs,mts,ts,tsx,vue}": "eslint --fix",
    "*.{css,less,scss}": "stylelint --fix",
    "*.{cjs,css,cts,html,js,json,jsx,less,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}": "prettier --write"
  },
  "prettier": "prettier-config-ali",
  "stylelint": {
    "extends": [
      "stylelint-config-ali",
      "stylelint-prettier/recommended"
    ]
  },
  "dependencies": {
    "@nuxt/ui": "^3.1.3",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.1.10",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "eslint": "^9.39.4",
    "eslint-config-ali": "^16.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-config-ali": "^1.5.0",
    "stylelint": "^16.26.1",
    "stylelint-config-ali": "^2.3.0",
    "stylelint-prettier": "^5.0.3"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
